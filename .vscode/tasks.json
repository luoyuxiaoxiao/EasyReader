{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gradle: assemble debug",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:assembleDebug", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANDROID_HOME": "/home/luoyu/Android/Sdk",
          "ANDROID_SDK_ROOT": "/home/luoyu/Android/Sdk",
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gradle"]
    },
    {
      "label": "Gradle: unit tests",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:testDebugUnitTest", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANDROID_HOME": "/home/luoyu/Android/Sdk",
          "ANDROID_SDK_ROOT": "/home/luoyu/Android/Sdk",
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$gradle"]
    },
    {
      "label": "Gradle: clean",
      "type": "shell",
      "command": "./gradlew",
      "args": ["clean", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANDROID_HOME": "/home/luoyu/Android/Sdk",
          "ANDROID_SDK_ROOT": "/home/luoyu/Android/Sdk",
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "problemMatcher": ["$gradle"]
    },
    {
      "label": "Android: install debug",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:installDebug", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANDROID_HOME": "/home/luoyu/Android/Sdk",
          "ANDROID_SDK_ROOT": "/home/luoyu/Android/Sdk",
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "problemMatcher": ["$gradle"],
      "detail": "Requires a connected Android device or a running emulator."
    },
    {
      "label": "Android: instrumentation tests",
      "type": "shell",
      "command": "./gradlew",
      "args": [":app:connectedDebugAndroidTest", "--no-daemon"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANDROID_HOME": "/home/luoyu/Android/Sdk",
          "ANDROID_SDK_ROOT": "/home/luoyu/Android/Sdk",
          "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk"
        }
      },
      "problemMatcher": ["$gradle"],
      "detail": "Requires a connected Android device or a running emulator."
    }
  ]
}
